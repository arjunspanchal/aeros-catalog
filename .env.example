# Copy this file to .env.local for local dev, or set these in Vercel's
# Environment Variables settings for production.

# Airtable Personal Access Token (create at https://airtable.com/create/tokens)
# Required scopes: data.records:read  |  Access to: Aeros Clearance Stock base
AIRTABLE_TOKEN=pat_xxxxxxxxxxxxxxxx

# Airtable base ID (pre-filled for Aeros Clearance Stock)
AIRTABLE_BASE_ID=appRMQ2om6bffGVBS

# Airtable table ID (pre-filled for Plain Items)
AIRTABLE_TABLE_ID=tblFJjqMIQhByuLHv

# Optional: specific view name to fetch from (e.g., "Public Catalog")
# Leave blank to fetch all records from the table
AIRTABLE_VIEW=

# --- Paper Bag Rate Calculator ---
# Reuses AIRTABLE_TOKEN above (same Airtable account, different base)
AIRTABLE_CALC_BASE_ID=appWO53wnIZKdKRlq
AIRTABLE_BAG_SPECS_TABLE=Bag Specs
AIRTABLE_QUOTES_TABLE=Quotes
AIRTABLE_BOX_QUOTES_TABLE=Box Quotes
AIRTABLE_CLIENTS_TABLE=Clients
AIRTABLE_OTP_TABLE=OTP Codes

# Paper RM master catalogue (read-only, shared across Aeros apps)
AIRTABLE_PAPER_RM_BASE_ID=appSllndIZszJSCma

# Fallback paper rate (₹/kg) used for client-side box quotes until per-paper rates wire up
DEFAULT_BOX_PAPER_RATE=70

# Master password for admin login on /calculator
ADMIN_PASSWORD=change-me

# HMAC secret for signing session cookies. `openssl rand -base64 32`.
SESSION_SECRET=replace-with-random-32-char-string

# Resend for OTP email delivery
RESEND_API_KEY=re_xxx
OTP_FROM_EMAIL=Aeros <noreply@yourdomain.com>

DEFAULT_CLIENT_MARGIN=15

# --- FactoryOS module ---
# Airtable base for FactoryOS (jobs, HR, RM inventory, etc.). Reuses
# AIRTABLE_TOKEN. The app also falls back to the legacy AIRTABLE_ORDERS_*
# names so you can migrate env vars at your own pace.
AIRTABLE_FACTORYOS_BASE_ID=appDEhKCVRAsYjSX2

# Table names (defaults shown — override only if you named them differently)
AIRTABLE_FACTORYOS_CLIENTS_TABLE=Clients
AIRTABLE_FACTORYOS_USERS_TABLE=Users
AIRTABLE_FACTORYOS_JOBS_TABLE=Jobs
AIRTABLE_FACTORYOS_UPDATES_TABLE=Job Status Updates
AIRTABLE_FACTORYOS_OTP_TABLE=OTP Codes
